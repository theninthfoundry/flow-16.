rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // User Progress validation helper
    function isValidUserProgress(data) {
      return data.uid is string && data.uid.size() <= 128
        && (data.wfocus == null || (data.wfocus is string && data.wfocus.size() <= 200))
        && (data.done == null || data.done is map)
        && (data.bkm == null || data.bkm is map)
        && (data.eliteDone == null || data.eliteDone is map)
        && (data.sundayAnswers == null || data.sundayAnswers is map)
        && (data.weeklyHabits == null || data.weeklyHabits is map)
        && (data.cheatSheets == null || data.cheatSheets is map)
        && (data.resources == null || data.resources is map)
        && (data.moduleNotes == null || data.moduleNotes is map);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) && isValidId(userId);
    }

    match /user_progress/{userId} {
      allow read: if isOwner(userId) && isValidId(userId);
      allow create, update: if isOwner(userId) && isValidId(userId) && isValidUserProgress(incoming());
    }
  }
}
